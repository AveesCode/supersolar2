rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Deny-by-default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'akumar2@uwm.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Participant Schemas & Validations
    function isValidParticipant(p) {
      return p.id is string
        && p.id.size() <= 128
        && p.name is string
        && p.name.size() > 0
        && p.name.size() <= 100
        && p.points is int
        && p.points >= 0
        && p.wins is int
        && p.wins >= 0
        && p.losses is int
        && p.losses >= 0
        && p.draws is int
        && p.draws >= 0
        && p.played is int
        && p.played >= 0
        && (p.status == 'active' || p.status == 'inactive')
        && (p.avatarColor is string && p.avatarColor.size() <= 50);
    }

    // Audit logs validation helper
    function isValidLog(l) {
      return l.id is string
        && l.id.size() <= 128
        && l.adminEmail is string
        && l.adminEmail.size() > 0
        && l.action is string
        && l.action.size() <= 100
        && l.details is string
        && l.details.size() <= 500
        && l.timestamp == request.time;
    }

    // System state validation helper
    function isValidSystemState(s) {
      return s.id is string
        && s.systemName is string
        && s.systemName.size() > 0
        && s.systemName.size() <= 100
        && s.isContestActive is bool
        && s.minPoints is int
        && s.maxPoints is int
        && s.updatedAt == request.time;
    }

    // Collection match rules:

    // 1. Participants collection
    match /participants/{participantId} {
      allow read: if true; // Standings are publicly viewable
      
      allow create: if (
        isAdmin() 
        && isValidId(participantId) 
        && isValidParticipant(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
      );

      allow update: if (
        isAdmin()
        && isValidId(participantId)
        && isValidParticipant(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
      );

      allow delete: if isAdmin() && isValidId(participantId);
    }

    // 2. Logs collection
    match /logs/{logId} {
      allow read: if isAdmin(); // Audit trails are admin-only
      
      allow create: if (
        isAdmin()
        && isValidId(logId)
        && isValidLog(incoming())
        && incoming().adminEmail == request.auth.token.email
      );

      // Prevents modifying or removing historical logs
      allow update, delete: if false; 
    }

    // 3. System collection 
    match /system/{systemId} {
      allow read: if true; // Everyone can read global game features (e.g. contestName, activity toggles)
      
      allow write: if (
        isAdmin()
        && isValidId(systemId)
        && (request.method == 'create' || request.method == 'update')
        && isValidSystemState(incoming())
      );
    }

    // 4. Admins list collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Securely configured server side or via console manually
    }
  }
}
